<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_beta_user_profile_form" model="ir.ui.view">
        <field name="name">res.users.beta.profile.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Profile">
                <header>
                    <button name="action_open_password_wizard" type="object" string="Change Password" class="btn-secondary"/>
                </header>
                <sheet class="beta_sheet">
                    <div class="oe_title beta_page_title">
                        <h1>Profile</h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="beta_role_label" readonly="1"/>
                        </group>
                        <group>
                            <field name="login"/>
                            <field name="email"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_server_beta_my_profile" model="ir.actions.server">
        <field name="name">My Profile</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_my_profile()</field>
    </record>
</odoo>
