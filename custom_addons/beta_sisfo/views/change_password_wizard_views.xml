<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_beta_change_password_wizard_form" model="ir.ui.view">
        <field name="name">beta.change.password.wizard.form</field>
        <field name="model">beta.change.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Password">
                <group>
                    <field name="user_id"/>
                    <field name="new_password" password="True"/>
                    <field name="confirm_password" password="True"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Save Password" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
