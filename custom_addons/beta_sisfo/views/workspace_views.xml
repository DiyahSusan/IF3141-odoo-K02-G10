<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_beta_workspace_search" model="ir.ui.view">
        <field name="name">beta.workspace.search</field>
        <field name="model">beta.workspace</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="state"/>
                <field name="owner_id"/>
                <filter name="workspace_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="workspace_ongoing" string="On Going" domain="[('state', '=', 'ongoing')]"/>
                <filter name="workspace_done" string="Done" domain="[('state', '=', 'done')]"/>
            </search>
        </field>
    </record>

    <record id="view_beta_workspace_tree" model="ir.ui.view">
        <field name="name">beta.workspace.tree</field>
        <field name="model">beta.workspace</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'ongoing'" decoration-primary="state == 'done'"/>
                <field name="owner_id"/>
                <field name="folder_count"/>
                <field name="requirement_count"/>
                <field name="document_count"/>
                <field name="validated_document_count"/>
            </tree>
        </field>
    </record>

    <record id="view_beta_workspace_kanban" model="ir.ui.view">
        <field name="name">beta.workspace.kanban</field>
        <field name="model">beta.workspace</field>
        <field name="arch" type="xml">
            <kanban class="beta_workspace_kanban">
                <field name="name"/>
                <field name="code"/>
                <field name="state"/>
                <field name="folder_count"/>
                <field name="requirement_count"/>
                <field name="document_count"/>
                <field name="pending_document_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_card beta_card">
                            <div class="beta_card_header">
                                <strong><field name="name"/></strong>
                                <span t-attf-class="badge rounded-pill beta_state_badge beta_state_#{record.state.raw_value}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="beta_card_subtitle">
                                <field name="code"/>
                            </div>
                            <div class="beta_card_stats">
                                <div>Folders: <field name="folder_count"/></div>
                                <div>Requirements: <field name="requirement_count"/></div>
                                <div>Documents: <field name="document_count"/></div>
                                <div>Pending: <field name="pending_document_count"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_beta_workspace_form" model="ir.ui.view">
        <field name="name">beta.workspace.form</field>
        <field name="model">beta.workspace</field>
        <field name="arch" type="xml">
            <form string="Project Workspace">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ongoing,done"/>
                </header>
                <sheet class="beta_sheet">
                    <div class="oe_title beta_page_title">
                        <h1><field name="name"/></h1>
                        <h2><field name="code"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="owner_id"/>
                            <field name="state"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="member_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group string="Readiness Overview" col="5">
                        <field name="folder_count" readonly="1"/>
                        <field name="requirement_count" readonly="1"/>
                        <field name="validated_requirement_count" readonly="1"/>
                        <field name="document_count" readonly="1"/>
                        <field name="validated_document_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Folders">
                            <field name="folder_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="state" widget="badge"/>
                                    <field name="document_count" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Requirements">
                            <field name="requirement_ids" readonly="1">
                                <tree>
                                    <field name="reference"/>
                                    <field name="name"/>
                                    <field name="client_name"/>
                                    <field name="state" widget="badge"/>
                                    <field name="readiness_percent"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Controlled Documents">
                            <field name="document_ids" readonly="1">
                                <tree>
                                    <field name="reference"/>
                                    <field name="folder_id"/>
                                    <field name="name"/>
                                    <field name="version"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_beta_workspace" model="ir.actions.act_window">
        <field name="name">Repository</field>
        <field name="res_model">beta.workspace</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="beta_sisfo.view_beta_workspace_search"/>
    </record>
</odoo>
