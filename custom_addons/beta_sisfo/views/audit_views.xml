<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_beta_audit_tree" model="ir.ui.view">
        <field name="name">beta.audit.log.tree</field>
        <field name="model">beta.audit.log</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="action_date" string="Timestamp"/>
                <field name="document_id" string="Document"/>
                <field name="project_id" string="Project"/>
                <field name="user_id" string="Done By"/>
                <field name="version"/>
                <field name="action_type" widget="badge"/>
                <field name="action"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="view_beta_audit_search" model="ir.ui.view">
        <field name="name">beta.audit.log.search</field>
        <field name="model">beta.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="action"/>
                <field name="action_type"/>
                <field name="document_id"/>
                <field name="project_id"/>
                <field name="user_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_audit_user" string="User" context="{'group_by': 'user_id'}"/>
                    <filter name="group_audit_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_audit_action_type" string="Action Type" context="{'group_by': 'action_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_beta_audit" model="ir.actions.act_window">
        <field name="name">Log Activity</field>
        <field name="res_model">beta.audit.log</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="beta_sisfo.view_beta_audit_search"/>
    </record>

    <record id="server_action_beta_audit_export_csv" model="ir.actions.server">
        <field name="name">Export CSV</field>
        <field name="model_id" ref="model_beta_audit_log"/>
        <field name="binding_model_id" ref="model_beta_audit_log"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = records.action_export_csv()</field>
    </record>

    <record id="server_action_beta_audit_export_xlsx" model="ir.actions.server">
        <field name="name">Export XLSX</field>
        <field name="model_id" ref="model_beta_audit_log"/>
        <field name="binding_model_id" ref="model_beta_audit_log"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = records.action_export_xlsx()</field>
    </record>

    <record id="server_action_beta_audit_export_pdf" model="ir.actions.server">
        <field name="name">Export PDF</field>
        <field name="model_id" ref="model_beta_audit_log"/>
        <field name="binding_model_id" ref="model_beta_audit_log"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = records.action_export_pdf()</field>
    </record>
</odoo>
