<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_beta_sisfo" model="ir.module.category">
        <field name="name">BETA SISFO</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_beta_sales" model="res.groups">
        <field name="name">BETA Sales</field>
        <field name="category_id" ref="beta_sisfo.module_category_beta_sisfo"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_beta_engineering" model="res.groups">
        <field name="name">BETA Engineering</field>
        <field name="category_id" ref="beta_sisfo.module_category_beta_sisfo"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_beta_project_officer" model="res.groups">
