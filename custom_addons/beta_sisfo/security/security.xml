        <field name="category_id" ref="beta_sisfo.module_category_beta_sisfo"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('project.group_project_user'))]"/>
    </record>

    <record id="group_beta_coo" model="res.groups">
        <field name="name">BETA COO</field>
