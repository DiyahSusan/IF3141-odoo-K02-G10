    <record id="rule_beta_workspace_member_visibility" model="ir.rule">
        <field name="name">Workspace visibility for team members</field>
        <field name="model_id" ref="model_beta_workspace"/>
        <field name="groups" eval="[(4, ref('beta_sisfo.group_beta_sales')), (4, ref('beta_sisfo.group_beta_engineering'))]"/>
        <field name="domain_force">['|', ('owner_id', '=', user.id), ('member_ids', 'in', [user.id])]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_beta_workspace_manager_visibility" model="ir.rule">
        <field name="name">Workspace visibility for managers</field>
        <field name="model_id" ref="model_beta_workspace"/>
        <field name="groups" eval="[(4, ref('beta_sisfo.group_beta_project_officer')), (4, ref('beta_sisfo.group_beta_coo'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

